{
  "name": "ts-script-template",
  "version": "0.0.1",
  "description": "",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "knip": "knip",
    "depcruise": "depcruise src/",
    "lint:md": "markdownlint-cli2",
    "lint:actions": "actionlint",
    "dev": "tsx src/index.ts"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "imports": {
    "#@/*": "./src/*"
  },
  "knip": {
    "ignoreBinaries": [
      "actionlint"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@commitlint/types": "^20.4.4",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.1.0",
    "dependency-cruiser": "^17.3.9",
    "eslint": "^9.39.4",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-perfectionist": "^5.6.0",
    "jiti": "^2.6.1",
    "knip": "^5.86.0",
    "lefthook": "^2.1.4",
    "markdownlint-cli2": "^0.21.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  }
}
